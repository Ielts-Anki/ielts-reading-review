# ============================================================
#  Cấu hình gửi email nhắc ôn tập qua Gmail
#  Cách dùng: sao chép file này thành ".env" rồi điền giá trị.
# ============================================================

# Địa chỉ Gmail dùng để GỬI mail
GMAIL_USER=ban@gmail.com

# App Password của Gmail (KHÔNG phải mật khẩu đăng nhập thường).
# Cách lấy: bật Xác minh 2 bước cho tài khoản Google, rồi vào
# https://myaccount.google.com/apppasswords để tạo mật khẩu ứng dụng.
# Dán cả 16 ký tự (có thể có khoảng trắng, vẫn dùng được).
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Địa chỉ NHẬN mail nhắc (thường là chính bạn). Bỏ trống sẽ gửi về GMAIL_USER.
REMINDER_TO=ban@gmail.com

# Link app để bấm vào từ trong email
APP_URL=http://localhost:3000

# Giờ gửi nhắc mỗi ngày (0-23), chỉ dùng cho chế độ "npm run remind:watch"
REMIND_HOUR=7

# Chu?i k?t n?i MongoDB
MONGODB_URI=mongodb://localhost:27017/ielts_reading_review
